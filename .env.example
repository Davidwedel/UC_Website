# Email Configuration
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Check interval in seconds (default: 300 = 5 minutes)
CHECK_INTERVAL=300

# Max age of recordings in days — older entries are deleted from the DB each cycle.
# Set to 0 (default) to keep recordings forever.
# RECORDING_MAX_AGE_DAYS=90

# Flask Configuration (optional)
FLASK_ENV=production

# Service schedule: SERVICE_N=HH:MM-HH:MM=Name[=hidden]
# Append =hidden to save recordings from that service as hidden by default.
# Omitting the flag (or using =visible) saves them as visible by default.
# SERVICE_1=10:35-13:00=Sunday Morning Service
# SERVICE_2=19:15-21:00=Sunday Evening Service
# SERVICE_3=10:05-10:30=Sunday School Opening=hidden
